# Copy to .env and fill in (never commit real keys).
# In Vercel / Netlify / Cloudflare, add these in Project → Environment Variables.

VITE_SUPABASE_URL=https://your-project-id.supabase.co
# Legacy anon JWT (eyJ...) or new publishable key (sb_publishable_...) from Project Settings → API / Connect
VITE_SUPABASE_ANON_KEY=your-anon-or-publishable-key
